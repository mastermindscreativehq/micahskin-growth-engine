generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Lead {
  id                       String    @id @default(cuid())
  fullName                 String
  email                    String?
  phone                    String?
  sourcePlatform           String
  skinConcern              String
  message                  String
  status                   String    @default("new")
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  campaign                 String?
  handle                   String?
  intentTag                String?
  sourceType               String?
  utmCampaign              String?
  utmContent               String?
  utmMedium                String?
  utmSource                String?
  utmTerm                  String?
  priority                 String    @default("low")
  followUp1                DateTime?
  followUp1Sent            Boolean   @default(false)
  followUp2                DateTime?
  followUp2Sent            Boolean   @default(false)
  followUp3                DateTime?
  followUp3Sent            Boolean   @default(false)
  initialMessageSent       Boolean   @default(false)
  suggestedReply           String?
  autoReplyEnabled         Boolean   @default(true)
  followUp1SentAt          DateTime?
  followUp2SentAt          DateTime?
  followUp3SentAt          DateTime?
  initialReplySentAt       DateTime?
  lastMessageChannel       String?
  lastMessageSentAt        DateTime?
  replyLock                Boolean   @default(false)
  lastDeliveredAt          DateTime?
  lastDeliveryChannel      String?
  lastDeliveryStatus       String?
  telegramChatId           String?
  telegramStarted          Boolean   @default(false)
  telegramUsername         String?
  engagementScore          String?
  intent                   String?
  telegramConnectedAt      DateTime?
  telegramLastMessage      String?
  telegramLastMessageAt    DateTime?
  telegramStage            String?
  telegramArea             String?
  telegramConcern          String?
  telegramDuration         String?
  telegramGoal             String?
  telegramProductsTried    String?
  telegramSeverity         String?
  telegramSkinType         String?
  telegramBudget           String?
  telegramFlowType         String?
  telegramProductsUsed     String?
  telegramRoutineGoal      String?
  telegramRoutineLevel     String?
  telegramSensitivity      String?
  checkInSendAfter         DateTime?
  checkInSent              Boolean   @default(false)
  checkInSentAt            DateTime?
  diagnosis                Json?
  diagnosisGeneratedAt     DateTime?
  diagnosisSendAfter       DateTime?
  diagnosisSent            Boolean   @default(false)
  diagnosisSentAt          DateTime?
  productRecoSendAfter     DateTime?
  productRecoSent          Boolean   @default(false)
  productRecoSentAt        DateTime?
  products                 Json?
  routine                  Json?
  diagnosisSummary         String?
  primaryConcern           String?
  secondaryConcern         String?
  routineType              String?
  productRecommendation    Json?
  recommendedProductsText  String?
  academyFitScore          Int?
  conversionIntent         String?
  urgencyLevel             String?
  confidenceScore          Int?
  nextBestAction           String?
  followupAngle            String?
  recommendedReply         String?
  diagnosisSource          String?
  diagnosedAt              DateTime?
  academyOfferSendAfter    DateTime?
  academyOfferSent         Boolean   @default(false)
  academyOfferSentAt       DateTime?
  academyOfferStatus       String?
  actionBlockedReason      String?
  checkInStatus            String?
  diagnosisStatus          String?
  lastActionAt             DateTime?
  lastActionType           String?
  productRecoStatus        String?
  consultOfferSendAfter    DateTime?
  consultOfferSent         Boolean   @default(false)
  consultOfferSentAt       DateTime?
  consultOfferStatus       String?
  courseOfferSendAfter     DateTime?
  courseOfferSent          Boolean   @default(false)
  courseOfferSentAt        DateTime?
  courseOfferStatus        String?
  conversionAt             DateTime?
  conversionType           String?
  conversionValue          Float?
  lastInteractionAt        DateTime?
  leadStage                String    @default("new")
  followUpIntent           String?
  followUpIntentAt         DateTime?
  conversionAttempts       Int       @default(0)
  conversionOfferPath      String?
  conversionOfferSendAfter DateTime?
  conversionOfferSent      Boolean   @default(false)
  conversionOfferSentAt    DateTime?
  conversionOfferStatus    String?
  conversionPath           String?
  conversionStage          String?
  lastConversionIntent     String?
  lastConversionTriggerAt  DateTime?
  lastManualActionAt       DateTime?
  lastManualActionBy       String?
  lastManualActionType     String?
  lastSalesMessagePreview  String?
  manualOverrideNote       String?
  paymentLinkLastSentAt    DateTime?
  productOfferSent         Boolean   @default(false)
  productOfferSentAt       DateTime?
  productOfferStatus       String?
  conversationMode         String?
  activeOffer              String?
  awaitingReplyFor         String?
  botMutedUntil            DateTime?
  followupSuppressed       Boolean   @default(false)
  lastBotIntent            String?
  lastUserIntent           String?
  lastMeaningfulBotAt      DateTime?
  lastMeaningfulUserAt     DateTime?
  academyPitchCount        Int       @default(0)
  productOfferCount        Int       @default(0)
  consultOfferCount        Int       @default(0)
  quoteStatus              String?
  productQuoteSentAt       DateTime?
  academyAccess            Boolean   @default(false)
  academyInviteCode        String?
  academyJoinedAt          DateTime?
  academyProgressStage     String?
  academyEngagementScore   Int?
  replies                  Reply[]
  quotes                   ProductQuote[]

  @@map("leads")
}

model SkincareProduct {
  id                  String    @id @default(cuid())
  productName         String
  normalizedName      String
  brand               String
  normalizedBrand     String
  category            String
  subcategory         String?
  concernsSupported   String[]
  skinTypesSupported  String[]
  sensitivityFriendly Boolean   @default(false)
  routineStep         String
  description         String?
  keyIngredients      String[]
  contraindications   String[]
  price               Float?
  currency            String    @default("NGN")
  priceBand           String?
  purchaseUrl         String?
  imageUrl            String?
  sourceStore         String    @default("manual")
  sourceType          String    @default("manual")
  country             String    @default("NG")
  market              String    @default("nigeria")
  availabilityStatus  String    @default("available")
  stockStatus         String    @default("in_stock")
  confidenceScore     Float?    @default(1.0)
  lastCheckedAt       DateTime?
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([normalizedName, normalizedBrand, sourceStore])
  @@index([category])
  @@index([priceBand])
  @@index([isActive])
  @@map("skincare_products")
}

model ProductIngestionLog {
  id            String    @id @default(cuid())
  source        String
  sourceStore   String?
  productsFound Int       @default(0)
  inserted      Int       @default(0)
  updated       Int       @default(0)
  skipped       Int       @default(0)
  duplicates    Int       @default(0)
  failed        Int       @default(0)
  status        String    @default("running")
  error         String?
  startedAt     DateTime  @default(now())
  completedAt   DateTime?
  metadata      Json?

  @@map("product_ingestion_logs")
}

model ProductQuote {
  id          String             @id @default(cuid())
  leadId      String
  status      String             @default("pending_review")
  totalAmount Float              @default(0)
  currency    String             @default("NGN")
  notes       String?
  reviewedBy  String?
  reviewedAt  DateTime?
  sentAt      DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  lead        Lead               @relation(fields: [leadId], references: [id])
  items       ProductQuoteItem[]

  @@index([leadId])
  @@index([status])
  @@map("product_quotes")
}

model ProductQuoteItem {
  id          String       @id @default(cuid())
  quoteId     String
  productId   String?
  productName String
  routineStep String?
  quantity    Int          @default(1)
  unitPrice   Float
  editedPrice Float?
  subtotal    Float
  notes       String?
  quote       ProductQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@map("product_quote_items")
}

model AcademyRegistration {
  id                         String    @id @default(cuid())
  fullName                   String
  email                      String
  phone                      String?
  businessType               String?
  experienceLevel            String
  goals                      String
  sourcePlatform             String
  status                     String    @default("new")
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
  campaign                   String?
  handle                     String?
  sourceType                 String?
  utmCampaign                String?
  utmContent                 String?
  utmMedium                  String?
  utmSource                  String?
  utmTerm                    String?
  telegramChatId             String?
  telegramStarted            Boolean   @default(false)
  telegramUsername           String?
  telegramStage              String?
  academyAmount              Int?
  academyPackage             String?
  academyStatus              String?
  paymentStatus              String?
  systemIncluded             Boolean?
  upgradeEligible            Boolean?
  deliveryCompletedAt        DateTime?
  deliveryNotes              String?
  deliveryOwner              String?
  deliveryTier               String?
  enrollmentStatus           String?
  implementationCallBooked   Boolean   @default(false)
  implementationCallBookedAt DateTime?
  implementationClient       Boolean   @default(false)
  implementationStage        String?
  implementationStatus       String?
  intakeBrandName            String?
  intakeBusinessStage        String?
  intakeBusinessType         String?
  intakeMainGoal             String?
  intakeNeedsAutomation      Boolean?
  intakeNeedsContent         Boolean?
  intakeNeedsLeadGen         Boolean?
  intakeProductsServices     String?
  intakeSalesChannel         String?
  intakeSupportMethod        String?
  intakeTopProblem           String?
  onboardingPath             String?
  onboardingSent             Boolean   @default(false)
  onboardingSentAt           DateTime?
  onboardingStatus           String?
  premiumFollowupRequired    Boolean   @default(false)
  premiumFollowupSentAt      DateTime?
  premiumIntakeCompletedAt   DateTime?
  premiumIntakeStage         String?
  premiumIntakeStatus        String?
  premiumOnboardingSent      Boolean   @default(false)
  premiumOnboardingSentAt    DateTime?
  systemSetupStatus          String?
  taskBuildStarted           Boolean   @default(false)
  taskCallBooked             Boolean   @default(false)
  taskDeliveryComplete       Boolean   @default(false)
  taskIntakeReviewed         Boolean   @default(false)
  taskScopeReady             Boolean   @default(false)
  academyLessonStatus        String?
  currentLesson              Int       @default(0)
  lessonsCompleted           Int       @default(0)
  lastLessonSentAt           DateTime?
  lastLessonCompletedAt      DateTime?
  nextLessonUnlockAt         DateTime?
  academyCompletionAt        DateTime?
  lessonCtaStatus            String?
  academyPaused              Boolean   @default(false)
  lastInboundAt              DateTime?

  @@map("academy_registrations")
}

model Reply {
  id             String   @id @default(cuid())
  leadId         String
  message        String
  channel        String
  detectedIntent String?
  createdAt      DateTime @default(now())
  lead           Lead     @relation(fields: [leadId], references: [id])

  @@map("replies")
}

model RawSocialItem {
  id             String              @id @default(cuid())
  platform       String
  sourceType     String
  sourceUrl      String?
  externalId     String              @unique
  username       String?
  displayName    String?
  text           String?
  matchedHashtag String?
  postedAt       DateTime?
  likesCount     Int                 @default(0)
  commentsCount  Int                 @default(0)
  rawJson        Json
  createdAt      DateTime            @default(now())
  decision       SocialLeadDecision?

  @@map("raw_social_items")
}

model SocialLeadDecision {
  id              String        @id @default(cuid())
  rawSocialItemId String        @unique
  intentType      String?
  concern         String?
  academyIntent   String?
  score           Int
  temperature     String
  decision        String
  reason          String?
  createdLeadId   String?
  createdAt       DateTime      @default(now())
  rawSocialItem   RawSocialItem @relation(fields: [rawSocialItemId], references: [id])

  @@map("social_lead_decisions")
}

model CommentScrapeTarget {
  id              String   @id @default(cuid())
  platform        String
  sourceDatasetId String
  sourceUrl       String?
  postUrl         String
  shortcode       String   @unique
  postType        String   @default("post")
  status          String   @default("pending")
  apifyRunId      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("comment_scrape_targets")
}

model MessageLog {
  id               String   @id @default(cuid())
  channel          String
  status           String
  createdAt        DateTime @default(now())
  error            String?
  providerResponse String?
  recordId         String
  type             String
  auto             Boolean  @default(false)
  triggerReason    String?
  deliveryChannel  String?
  fallbackUsed     Boolean  @default(false)
  recipient        String?

  @@map("message_logs")
}

model OrchestrationRun {
  id                 String   @id @default(uuid())
  platform           String
  discoveryDatasetId String
  commentRunId       String?
  commentDatasetId   String?
  status             String   @default("running")
  stage4Result       Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("orchestration_runs")
}

model InstagramCommentLead {
  id                     String    @id @default(cuid())
  platform               String    @default("instagram")
  sourceDatasetId        String?
  apifyRunId             String?
  commentId              String?   @unique
  postUrl                String?
  commentText            String?
  commentedAt            DateTime?
  commenterUsername      String?
  commenterProfilePicUrl String?
  ownerUsername          String?
  rawJson                Json?
  status                 String    @default("new")
  intentScore            Int       @default(0)
  intentLabel            String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@index([commenterUsername])
  @@index([status])
  @@index([sourceDatasetId])
}

model TelegramSession {
  id        String   @id @default(uuid())
  userId    String   @unique
  stage     String
  data      Json
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Access audit log — records every gate decision (allow/deny) for a Telegram user.
/// This model contains row level security managed by Supabase.
model academy_access_logs {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  telegram_id String?
  username    String?
  invite_code String?
  payload     String?
  decision    String
  reason      String?
  metadata    Json     @default("{}")
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  @@index([created_at(sort: Desc)], map: "idx_academy_access_logs_created_at")
  @@index([decision], map: "idx_academy_access_logs_decision")
  @@index([invite_code], map: "idx_academy_access_logs_invite_code")
  @@index([telegram_id], map: "idx_academy_access_logs_telegram_id")
}

/// Authorised academy members — the live access gate.
/// Populated by n8n when an invite code is redeemed.
/// This model contains row level security managed by Supabase.
model academy_authorized_users {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  telegram_id   String    @unique
  username      String?
  first_name    String?
  last_name     String?
  invite_code   String?
  source        String?
  access_status String    @default("active")
  approved_at   DateTime  @default(now()) @db.Timestamptz(6)
  last_seen_at  DateTime? @db.Timestamptz(6)
  metadata      Json      @default("{}")
  created_at    DateTime  @default(now()) @db.Timestamptz(6)
  updated_at    DateTime  @default(now()) @db.Timestamptz(6)

  @@index([invite_code], map: "idx_academy_authorized_users_invite_code")
  @@index([access_status], map: "idx_academy_authorized_users_status")
  @@index([telegram_id], map: "idx_academy_authorized_users_telegram_id")
}

/// Blocked Telegram IDs — permanently or temporarily denied academy access.
/// This model contains row level security managed by Supabase.
model academy_blocked_ids {
  telegram_id String    @id
  blocked_at  DateTime  @default(now()) @db.Timestamptz(6)
  reason      String?
  expires_at  DateTime? @db.Timestamptz(6)
}

/// Academy invite codes — controls who can join and how many times each code can be used.
/// This model contains row level security managed by Supabase.
model academy_invites {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invite_code String    @unique
  source      String?
  created_by  String?
  is_active   Boolean   @default(true)
  max_uses    Int       @default(1)
  used_count  Int       @default(0)
  expires_at  DateTime? @db.Timestamptz(6)
  metadata    Json      @default("{}")
  created_at  DateTime  @default(now()) @db.Timestamptz(6)
  updated_at  DateTime  @default(now()) @db.Timestamptz(6)

  @@index([is_active], map: "idx_academy_invites_active")
  @@index([invite_code], map: "idx_academy_invites_code")
  @@index([expires_at], map: "idx_academy_invites_expires_at")
  @@index([source], map: "idx_academy_invites_source")
}

/// Quiz session state — tracks per-user quiz progress in the n8n academy bot.
model quiz_sessions {
  id         BigInt   @id @default(autoincrement())
  chat_id    String   @unique
  state      String   @default("IN_QUIZ")
  quiz_data  Json?
  q_index    Int      @default(0)
  score      Int      @default(0)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)

  @@index([chat_id], map: "idx_quiz_sessions_chat_id")
  @@index([state], map: "idx_quiz_sessions_state")
}
