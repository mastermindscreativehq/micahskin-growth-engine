generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Skincare enquiries from TikTok / Instagram visitors
model Lead {
  id             String   @id @default(cuid())
  fullName       String
  email          String?
  phone          String?
  sourcePlatform String   // TikTok | Instagram | Other
  sourceType     String?  // bio_form | dm | comment | story_reply | manual
  handle         String?  // Instagram / TikTok username
  campaign       String?  // campaign slug from bio link or ad
  intentTag      String?  // free-form intent label
  skinConcern    String   // acne | dark_spots | stretch_marks | dry_skin | hyperpigmentation | body_care | other
  message        String
  status         String   @default("new") // new | contacted | engaged | interested | closed
  priority       String   @default("low") // high | medium | low
  suggestedReply String?  // auto-generated reply message on lead creation
  followUp1      DateTime? // +1 hour
  followUp2      DateTime? // +6 hours
  followUp3      DateTime? // +24 hours
  initialMessageSent  Boolean   @default(false) // auto initial message sent?
  followUp1Sent       Boolean   @default(false) // scheduler alerted for follow-up 1?
  followUp2Sent       Boolean   @default(false) // scheduler alerted for follow-up 2?
  followUp3Sent       Boolean   @default(false) // scheduler alerted for follow-up 3?
  initialReplySentAt  DateTime?                 // when initial reply was executed via CRM
  followUp1SentAt     DateTime?                 // when follow-up 1 was executed via CRM
  followUp2SentAt     DateTime?                 // when follow-up 2 was executed via CRM
  followUp3SentAt     DateTime?                 // when follow-up 3 was executed via CRM
  lastMessageSentAt    DateTime?                // timestamp of last executed send
  lastMessageChannel   String?                  // channel of last executed send (e.g. telegram)
  lastDeliveryChannel  String?                  // actual channel used to reach lead: email | whatsapp | telegram_fallback
  lastDeliveredAt      DateTime?                // when the message was actually delivered to the lead
  lastDeliveryStatus   String?                  // sent | skipped | failed
  autoReplyEnabled    Boolean   @default(true)  // whether auto-reply is enabled for this lead
  replyLock           Boolean   @default(false) // transient lock held by auto-trigger during send
  telegramUsername        String?   // Telegram @username (without @)
  telegramChatId          String?   // Telegram chat_id — set when lead taps /start in bot
  telegramStarted         Boolean   @default(false) // true once lead has started the Telegram bot
  telegramConnectedAt     DateTime? // when lead first connected via /start
  telegramLastMessage     String?   // last message text received from lead via Telegram
  telegramLastMessageAt   DateTime? // when the last Telegram message was received
  intent                  String?   // concern bucket: acne | hyperpigmentation | dry_skin | stretch_marks | body_care | sensitive_skin | general | price | routine | urgent
  engagementScore         String?   // high | medium | low — computed from reply speed, length, frequency
  telegramFlowType          String?   // routine | concern — classified once at connected stage, never changed
  telegramStage             String?   // connected | concern_pending | duration_pending | area_pending | skin_type_pending | products_tried_pending | severity_pending | goal_pending | routine_goal_pending | products_used_pending | sensitivity_pending | budget_pending | routine_level_pending | intake_complete | awaiting_human_review
  telegramConcern           String?   // concern path: raw text of stated skin concern
  telegramDuration          String?   // concern path: how long they have had the issue
  telegramArea              String?   // shared: face | body | both (free text)
  telegramSkinType          String?   // shared: oily | dry | combination | sensitive | not sure (free text)
  telegramProductsTried     String?   // concern path: products or remedies already tried
  telegramSeverity          String?   // concern path: mild | moderate | severe (free text)
  telegramGoal              String?   // concern path: desired result
  telegramRoutineGoal       String?   // routine path: desired result (brighter, glow, even tone, etc.)
  telegramProductsUsed      String?   // routine path: products currently using
  telegramSensitivity       String?   // routine path: skin sensitivity / reactivity
  telegramBudget            String?   // routine path: budget | mid-range | premium
  telegramRoutineLevel      String?   // routine path: simple | balanced | complete
  utmSource      String?
  replies        Reply[]
  utmMedium      String?
  utmCampaign    String?
  utmContent     String?
  utmTerm        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("leads")
}

// Academy masterclass sign-ups
model AcademyRegistration {
  id              String   @id @default(cuid())
  fullName        String
  email           String
  phone           String?
  businessType    String?
  experienceLevel String   // beginner | intermediate | advanced
  goals           String
  sourcePlatform  String   // TikTok | Instagram | Other
  sourceType      String?  // bio_form | dm | comment | story_reply | manual
  handle          String?  // Instagram / TikTok username
  campaign        String?
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  utmContent      String?
  utmTerm         String?
  status           String   @default("new") // new | contacted | paid | onboarded | closed
  telegramUsername String?                  // Telegram @username (without @)
  telegramChatId   String?                  // Telegram chat_id — set when registrant taps /start in bot
  telegramStarted  Boolean  @default(false) // true once registrant has started the Telegram bot
  telegramStage    String?                  // connected | asked_goal | goal_received
  academyPackage   String?  // premium | basic
  academyAmount    Int?     // 60000 | 50000
  paymentStatus    String?  // pending | paid
  academyStatus    String?  // not_enrolled | enrolled
  systemIncluded   Boolean? // true for premium
  upgradeEligible  Boolean? // true for basic
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("academy_registrations")
}

// Incoming replies from leads (via webhook or manual CRM entry)
model Reply {
  id             String   @id @default(cuid())
  leadId         String
  message        String
  channel        String   // telegram | instagram | tiktok | manual
  detectedIntent String?  // PRICE | HOT | DELAY | DEAD | UNKNOWN
  createdAt      DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id])

  @@map("replies")
}

// Raw items ingested from social media scrapers (Apify, etc.)
model RawSocialItem {
  id             String   @id @default(cuid())
  platform       String   // instagram | tiktok | youtube | etc.
  sourceType     String   // hashtag_post | profile_post | comment | etc.
  sourceUrl      String?
  externalId     String   @unique  // Apify/platform post ID — deduplication key
  username       String?
  displayName    String?
  text           String?  // caption or comment text
  matchedHashtag String?  // first hashtag that triggered the scrape
  postedAt       DateTime?
  likesCount     Int      @default(0)
  commentsCount  Int      @default(0)
  rawJson        Json     // full Apify item payload for audit
  createdAt      DateTime @default(now())

  decision SocialLeadDecision?

  @@map("raw_social_items")
}

// Classification + scoring decision made for each raw social item
model SocialLeadDecision {
  id              String   @id @default(cuid())
  rawSocialItemId String   @unique
  rawSocialItem   RawSocialItem @relation(fields: [rawSocialItemId], references: [id])
  intentType      String?  // consumer | academy | noise
  concern         String?  // acne | hyperpigmentation | stretch_marks | etc.
  academyIntent   String?  // start_brand | skincare_training | private_label | etc.
  score           Int
  temperature     String   // hot | warm | cold | reject
  decision        String   // ingest | reject
  reason          String?  // human-readable explanation of score/decision
  createdLeadId   String?  // Lead.id if a CRM lead was created from this item
  createdAt       DateTime @default(now())

  @@map("social_lead_decisions")
}

// Post/reel URLs extracted from discovery datasets and queued for comment harvesting
model CommentScrapeTarget {
  id              String   @id @default(cuid())
  platform        String   // 'instagram'
  sourceDatasetId String   // Apify discovery dataset ID this target came from
  sourceUrl       String?  // raw URL from Apify item before normalisation
  postUrl         String   // canonical https://www.instagram.com/p/{code}/ or /reel/{code}/
  shortcode       String   @unique  // post shortcode — deduplication key
  postType        String   @default("post")  // 'post' | 'reel'
  status          String   @default("pending")  // pending | running | done | failed
  apifyRunId      String?  // Apify run ID once triggered
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("comment_scrape_targets")
}

// Tracks every outbound message sent to a lead or registrant
model MessageLog {
  id               String   @id @default(cuid())
  type             String   // lead | academy
  recordId         String   // id of the Lead or AcademyRegistration
  channel          String   // telegram | email | whatsapp | sms | other
  status           String   // sent | failed | skipped
  providerResponse String?  // raw JSON response from provider on success
  error            String?  // error message when status is failed
  auto             Boolean  @default(false)  // true when triggered by auto-trigger service
  triggerReason    String?                   // initial_auto | fu1_auto | manual
  recipient        String?                   // actual recipient: email address, phone, or 'telegram_admin'
  deliveryChannel  String?                   // actual channel used: email | whatsapp | telegram_fallback
  fallbackUsed     Boolean  @default(false)  // true when telegram admin fallback was used instead of direct channel
  createdAt        DateTime @default(now())

  @@map("message_logs")
}
