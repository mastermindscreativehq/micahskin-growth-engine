generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Skincare enquiries from TikTok / Instagram visitors
model Lead {
  id             String   @id @default(cuid())
  fullName       String
  email          String?
  phone          String?
  sourcePlatform String   // TikTok | Instagram | Other
  sourceType     String?  // bio_form | dm | comment | story_reply | manual
  handle         String?  // Instagram / TikTok username
  campaign       String?  // campaign slug from bio link or ad
  intentTag      String?  // free-form intent label
  skinConcern    String   // acne | dark_spots | stretch_marks | dry_skin | hyperpigmentation | body_care | other
  message        String
  status         String   @default("new") // new | contacted | engaged | interested | closed
  priority       String   @default("low") // high | medium | low
  suggestedReply String?  // auto-generated reply message on lead creation
  followUp1      DateTime? // +1 hour
  followUp2      DateTime? // +6 hours
  followUp3      DateTime? // +24 hours
  initialMessageSent  Boolean   @default(false) // auto initial message sent?
  followUp1Sent       Boolean   @default(false) // scheduler alerted for follow-up 1?
  followUp2Sent       Boolean   @default(false) // scheduler alerted for follow-up 2?
  followUp3Sent       Boolean   @default(false) // scheduler alerted for follow-up 3?
  initialReplySentAt  DateTime?                 // when initial reply was executed via CRM
  followUp1SentAt     DateTime?                 // when follow-up 1 was executed via CRM
  followUp2SentAt     DateTime?                 // when follow-up 2 was executed via CRM
  followUp3SentAt     DateTime?                 // when follow-up 3 was executed via CRM
  lastMessageSentAt    DateTime?                // timestamp of last executed send
  lastMessageChannel   String?                  // channel of last executed send (e.g. telegram)
  lastDeliveryChannel  String?                  // actual channel used to reach lead: email | whatsapp | telegram_fallback
  lastDeliveredAt      DateTime?                // when the message was actually delivered to the lead
  lastDeliveryStatus   String?                  // sent | skipped | failed
  autoReplyEnabled    Boolean   @default(true)  // whether auto-reply is enabled for this lead
  replyLock           Boolean   @default(false) // transient lock held by auto-trigger during send
  telegramUsername        String?   // Telegram @username (without @)
  telegramChatId          String?   // Telegram chat_id — set when lead taps /start in bot
  telegramStarted         Boolean   @default(false) // true once lead has started the Telegram bot
  telegramConnectedAt     DateTime? // when lead first connected via /start
  telegramLastMessage     String?   // last message text received from lead via Telegram
  telegramLastMessageAt   DateTime? // when the last Telegram message was received
  intent                  String?   // concern bucket: acne | hyperpigmentation | dry_skin | stretch_marks | body_care | sensitive_skin | general | price | routine | urgent
  engagementScore         String?   // high | medium | low — computed from reply speed, length, frequency
  telegramFlowType          String?   // routine | concern — classified once at connected stage, never changed
  telegramStage             String?   // connected | intake_complete | diagnosis_sent | awaiting_checkin_reply | checkin_sent | checkin_replied | product_reco_sent | awaiting_product_reply | product_reply_received | post_diagnosis_engaged | awaiting_human_review
  telegramConcern           String?   // concern path: raw text of stated skin concern
  telegramDuration          String?   // concern path: how long they have had the issue
  telegramArea              String?   // shared: face | body | both (free text)
  telegramSkinType          String?   // shared: oily | dry | combination | sensitive | not sure (free text)
  telegramProductsTried     String?   // concern path: products or remedies already tried
  telegramSeverity          String?   // concern path: mild | moderate | severe (free text)
  telegramGoal              String?   // concern path: desired result
  telegramRoutineGoal       String?   // routine path: desired result (brighter, glow, even tone, etc.)
  telegramProductsUsed      String?   // routine path: products currently using
  telegramSensitivity       String?   // routine path: skin sensitivity / reactivity
  telegramBudget            String?   // routine path: budget | mid-range | premium
  telegramRoutineLevel      String?   // routine path: simple | balanced | complete
  // ── Diagnosis output (generated once when intake_complete) ────────────────
  diagnosis               Json?     // { text: string, notes: string[] }
  routine                 Json?     // { morning: string[], night: string[] }
  products                Json?     // { recommendations: string[] }
  diagnosisGeneratedAt    DateTime?

  // ── Enriched diagnosis fields (generated by diagnosisEngineService) ───────
  diagnosisSummary         String?   // human-readable CRM summary
  primaryConcern           String?   // acne | hyperpigmentation | dry_skin | etc.
  secondaryConcern         String?   // optional secondary issue
  routineType              String?   // simple_routine | acne_control | brightening | etc.
  productRecommendation    Json?     // { cleanser, treatment, moisturizer, sunscreen, notes[] }
  recommendedProductsText  String?   // plain-text product bucket summary
  academyFitScore          Int?      // 0–100
  conversionIntent         String?   // product | academy | consultation | undecided
  urgencyLevel             String?   // low | medium | high
  confidenceScore          Int?      // 0–100 — how confident the diagnosis is
  nextBestAction           String?   // recommend_routine | recommend_product | manual_consult | push_academy | nurture
  followupAngle            String?   // internal: best follow-up angle
  recommendedReply         String?   // draft reply for operator / CRM (NOT auto-sent)
  diagnosisSource          String?   // telegram_intake | instagram_comment | crm_data
  diagnosedAt              DateTime?

  // ── Auto follow-up direct sends (separate from admin alert system) ─────────
  diagnosisSendAfter      DateTime? // intake_complete + 1 hour
  diagnosisSent           Boolean   @default(false)
  diagnosisSentAt         DateTime?
  checkInSendAfter        DateTime? // intake_complete + 24 hours
  checkInSent             Boolean   @default(false)
  checkInSentAt           DateTime?
  productRecoSendAfter    DateTime? // intake_complete + 3 days
  productRecoSent         Boolean   @default(false)
  productRecoSentAt       DateTime?

  // ── Action Engine state tracking (Phase 17) ──────────────────────────────────
  diagnosisStatus       String?   // pending | sent | skipped | failed | blocked
  checkInStatus         String?   // pending | sent | skipped | failed | blocked
  productRecoStatus     String?   // pending | sent | skipped | failed | blocked
  academyOfferSendAfter DateTime? // set by diagnosis engine when academyFitScore >= threshold
  academyOfferSent      Boolean   @default(false) // atomic claim flag
  academyOfferSentAt    DateTime?
  academyOfferStatus    String?   // pending | sent | skipped | failed | blocked
  lastActionType        String?   // last action executed by the engine
  lastActionAt          DateTime? // when the last action ran
  actionBlockedReason   String?   // why automation was blocked for this lead

  // ── Conversion Engine — consult + course monetisation offers (Phase 18) ──────
  consultOfferSendAfter DateTime? // diagnosedAt + 2 hours (set by diagnosis engine)
  consultOfferSent      Boolean   @default(false)
  consultOfferSentAt    DateTime?
  consultOfferStatus    String?   // pending | sent | skipped | failed | blocked
  courseOfferSendAfter  DateTime? // diagnosedAt + 2 days (set by diagnosis engine)
  courseOfferSent       Boolean   @default(false)
  courseOfferSentAt     DateTime?
  courseOfferStatus     String?   // pending | sent | skipped | failed | blocked

  // ── Conversion Tracking (Phase 18) ─────────────────────────────────────────
  leadStage         String    @default("new") // new | interested | engaged | converted
  conversionType    String?   // academy_paid | consult_booked
  conversionValue   Float?    // revenue amount when applicable
  conversionAt      DateTime? // when conversion was confirmed
  lastInteractionAt DateTime? // last click / signup / payment event

  // ── Post-diagnosis follow-up tracking ────────────────────────────────────────
  followUpIntent    String?   // progress_positive | no_change_yet | irritation | confused_about_routine | has_not_started | needs_product_help | wants_human_support | general_update
  followUpIntentAt  DateTime? // when the follow-up intent was last detected

  // ── Conversion Trigger Layer (Phase 21) ──────────────────────────────────────
  conversionStage          String?   // none | interested | offer_sent | payment_pending | converted | declined
  conversionPath           String?   // product_offer | consult_offer | academy_offer | no_offer
  lastConversionIntent     String?   // follow-up intent that triggered the last conversion action
  lastConversionTriggerAt  DateTime? // when the last auto conversion was triggered
  conversionAttempts       Int       @default(0)

  // ── Conversation Brain + Reply Governor (Phase 22) ─────────────────────────
  // Conversation mode — explicit state the orchestration layer writes to
  conversationMode      String?   // intake | diagnosis_sent | checkin_active | product_reco_active | academy_pitch_active | consult_active | payment_pending | human_manual_mode | closed
  activeOffer           String?   // product | academy | consult — currently active offer type being pursued
  awaitingReplyFor      String?   // what the bot last asked the user about / is waiting on
  botMutedUntil         DateTime? // all automation suppressed until this timestamp (set after manual sends or active product/academy conversations)
  followupSuppressed    Boolean   @default(false) // hard admin flag: suppress all automated follow-ups for this lead
  lastBotIntent         String?   // what the bot's last outbound message was intended to do
  lastUserIntent        String?   // 12-bucket intent from the user's last inbound message
  lastMeaningfulBotAt   DateTime? // when the bot last sent a contextual (non-generic) message
  lastMeaningfulUserAt  DateTime? // when the user last sent a meaningful (non-trivial) message
  academyPitchCount     Int       @default(0) // cumulative count of academy pitches sent to this lead
  productOfferCount     Int       @default(0) // cumulative count of product offers / product answers sent
  consultOfferCount     Int       @default(0) // cumulative count of consult offers sent

  // Manual CRM action tracking
  lastManualActionType     String?   // product_offer | consult_offer | academy_offer | custom_message | resend_payment
  lastManualActionAt       DateTime?
  lastManualActionBy       String?   // admin name who triggered it
  manualOverrideNote       String?

  // Product offer state (distinct from productRecoSent — this is the explicit purchase CTA)
  productOfferSent         Boolean   @default(false)
  productOfferSentAt       DateTime?
  productOfferStatus       String?   // pending | sent | skipped | failed | blocked

  // Queued reply-triggered conversion offer (picked up by action engine)
  conversionOfferSendAfter DateTime?
  conversionOfferSent      Boolean   @default(false)
  conversionOfferSentAt    DateTime?
  conversionOfferStatus    String?   // pending | sent | skipped | failed | blocked
  conversionOfferPath      String?   // product_offer | consult_offer | academy_offer

  // Payment + message tracking
  paymentLinkLastSentAt    DateTime?
  lastSalesMessagePreview  String?

  utmSource      String?
  replies        Reply[]
  utmMedium      String?
  utmCampaign    String?
  utmContent     String?
  utmTerm        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("leads")
}

// Academy masterclass sign-ups
model AcademyRegistration {
  id              String   @id @default(cuid())
  fullName        String
  email           String
  phone           String?
  businessType    String?
  experienceLevel String   // beginner | intermediate | advanced
  goals           String
  sourcePlatform  String   // TikTok | Instagram | Other
  sourceType      String?  // bio_form | dm | comment | story_reply | manual
  handle          String?  // Instagram / TikTok username
  campaign        String?
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  utmContent      String?
  utmTerm         String?
  status           String   @default("new") // new | contacted | paid | onboarded | closed
  telegramUsername String?                  // Telegram @username (without @)
  telegramChatId   String?                  // Telegram chat_id — set when registrant taps /start in bot
  telegramStarted  Boolean  @default(false) // true once registrant has started the Telegram bot
  telegramStage    String?                  // connected | asked_goal | goal_received
  academyPackage   String?  // premium | basic
  academyAmount    Int?     // 60000 | 50000
  paymentStatus    String?  // pending | paid
  academyStatus    String?  // not_enrolled | enrolled
  systemIncluded   Boolean? // true for premium
  upgradeEligible  Boolean? // true for basic

  // ── Post-payment onboarding state (Phase 19) ────────────────────────────────
  enrollmentStatus        String?   // enrolled | cancelled
  onboardingStatus        String?   // pending | sent | failed | skipped
  onboardingSent          Boolean   @default(false) // atomic claim flag — prevents duplicate sends
  onboardingPath          String?   // basic | premium
  onboardingSentAt        DateTime?
  premiumFollowupRequired Boolean   @default(false) // true for premium — requires implementation setup session
  premiumFollowupSentAt   DateTime? // when admin was notified about premium follow-up

  // ── Premium Delivery Pipeline (Phase 20) ─────────────────────────────────────
  deliveryTier              String?   // basic | premium — set on payment confirmation
  implementationClient      Boolean   @default(false) // true for premium buyers
  implementationStatus      String?   // pending | active | paused | completed | cancelled
  implementationStage       String?   // paid | onboarding_sent | intake_pending | intake_complete | review_pending | strategy_call_pending | strategy_call_booked | build_pending | build_in_progress | delivered | active
  premiumIntakeStatus       String?   // pending | in_progress | complete | skipped
  premiumIntakeCompletedAt  DateTime?
  implementationCallBooked  Boolean   @default(false)
  implementationCallBookedAt DateTime?
  systemSetupStatus         String?   // not_started | in_progress | complete
  deliveryCompletedAt       DateTime?
  deliveryOwner             String?
  deliveryNotes             String?

  // ── Premium intake answers (collected via Telegram flow) ─────────────────────
  intakeBrandName           String?
  intakeBusinessType        String?
  intakeBusinessStage       String?
  intakeProductsServices    String?
  intakeSalesChannel        String?
  intakeTopProblem          String?
  intakeMainGoal            String?
  intakeNeedsLeadGen        Boolean?
  intakeNeedsAutomation     Boolean?
  intakeNeedsContent        Boolean?
  intakeSupportMethod       String?

  // ── Operational task flags (admin checklist) ─────────────────────────────────
  taskIntakeReviewed        Boolean   @default(false)
  taskScopeReady            Boolean   @default(false)
  taskCallBooked            Boolean   @default(false)
  taskBuildStarted          Boolean   @default(false)
  taskDeliveryComplete      Boolean   @default(false)

  // ── Premium onboarding send tracking ─────────────────────────────────────────
  premiumOnboardingSent     Boolean   @default(false) // atomic claim — prevents duplicate sends
  premiumOnboardingSentAt   DateTime?
  premiumIntakeStage        String?   // intake_brand_name | intake_business_type | intake_business_stage | intake_products_services | intake_sales_channel | intake_top_problem | intake_main_goal | intake_lead_gen | intake_automation | intake_content | intake_support_method | done

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("academy_registrations")
}

// Incoming replies from leads (via webhook or manual CRM entry)
model Reply {
  id             String   @id @default(cuid())
  leadId         String
  message        String
  channel        String   // telegram | instagram | tiktok | manual
  detectedIntent String?  // PRICE | HOT | DELAY | DEAD | UNKNOWN
  createdAt      DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id])

  @@map("replies")
}

// Raw items ingested from social media scrapers (Apify, etc.)
model RawSocialItem {
  id             String   @id @default(cuid())
  platform       String   // instagram | tiktok | youtube | etc.
  sourceType     String   // hashtag_post | profile_post | comment | etc.
  sourceUrl      String?
  externalId     String   @unique  // Apify/platform post ID — deduplication key
  username       String?
  displayName    String?
  text           String?  // caption or comment text
  matchedHashtag String?  // first hashtag that triggered the scrape
  postedAt       DateTime?
  likesCount     Int      @default(0)
  commentsCount  Int      @default(0)
  rawJson        Json     // full Apify item payload for audit
  createdAt      DateTime @default(now())

  decision SocialLeadDecision?

  @@map("raw_social_items")
}

// Classification + scoring decision made for each raw social item
model SocialLeadDecision {
  id              String   @id @default(cuid())
  rawSocialItemId String   @unique
  rawSocialItem   RawSocialItem @relation(fields: [rawSocialItemId], references: [id])
  intentType      String?  // consumer | academy | noise
  concern         String?  // acne | hyperpigmentation | stretch_marks | etc.
  academyIntent   String?  // start_brand | skincare_training | private_label | etc.
  score           Int
  temperature     String   // hot | warm | cold | reject
  decision        String   // ingest | reject
  reason          String?  // human-readable explanation of score/decision
  createdLeadId   String?  // Lead.id if a CRM lead was created from this item
  createdAt       DateTime @default(now())

  @@map("social_lead_decisions")
}

// Post/reel URLs extracted from discovery datasets and queued for comment harvesting
model CommentScrapeTarget {
  id              String   @id @default(cuid())
  platform        String   // 'instagram'
  sourceDatasetId String   // Apify discovery dataset ID this target came from
  sourceUrl       String?  // raw URL from Apify item before normalisation
  postUrl         String   // canonical https://www.instagram.com/p/{code}/ or /reel/{code}/
  shortcode       String   @unique  // post shortcode — deduplication key
  postType        String   @default("post")  // 'post' | 'reel'
  status          String   @default("pending")  // pending | running | done | failed
  apifyRunId      String?  // Apify run ID once triggered
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("comment_scrape_targets")
}

// Tracks every outbound message sent to a lead or registrant
model MessageLog {
  id               String   @id @default(cuid())
  type             String   // lead | academy
  recordId         String   // id of the Lead or AcademyRegistration
  channel          String   // telegram | email | whatsapp | sms | other
  status           String   // sent | failed | skipped
  providerResponse String?  // raw JSON response from provider on success
  error            String?  // error message when status is failed
  auto             Boolean  @default(false)  // true when triggered by auto-trigger service
  triggerReason    String?                   // initial_auto | fu1_auto | manual
  recipient        String?                   // actual recipient: email address, phone, or 'telegram_admin'
  deliveryChannel  String?                   // actual channel used: email | whatsapp | telegram_fallback
  fallbackUsed     Boolean  @default(false)  // true when telegram admin fallback was used instead of direct channel
  createdAt        DateTime @default(now())

  @@map("message_logs")
}

// Tracks a full orchestration run (Stage 1→4) for status polling and audit
model OrchestrationRun {
  id                 String   @id @default(uuid())
  platform           String   // 'instagram'
  discoveryDatasetId String
  commentRunId       String?  // Apify run ID returned by Stage 3 (null when no targets queued)
  commentDatasetId   String?  // Apify output dataset ID — populated once run SUCCEEDS
  status             String   @default("running")  // running | completed | failed
  stage4Result       Json?    // result from importInstagramCommentDataset
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("orchestration_runs")
}

//
model InstagramCommentLead {
  id               String   @id @default(cuid())
  platform         String   @default("instagram")
  sourceDatasetId  String?
  apifyRunId       String?
  commentId        String?  @unique
  postUrl          String?
  commentText      String?  @db.Text
  commentedAt      DateTime?
  commenterUsername String?
  commenterProfilePicUrl String?
  ownerUsername    String?
  rawJson          Json?
  status           String   @default("new")
  intentScore      Int      @default(0)
  intentLabel      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([commenterUsername])
  @@index([status])
  @@index([sourceDatasetId])
}

//
model TelegramSession {
  id        String   @id @default(uuid())
  userId    String   @unique
  stage     String
  data      Json
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
