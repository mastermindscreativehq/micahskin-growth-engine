# ── Database ─────────────────────────────────────────────────────────────────
# Supabase pooler URL (used by Prisma at runtime)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true
# Supabase direct URL (used by Prisma migrations)
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000

# Production Vercel URL. Local dev: http://localhost:5173
# Used by Paystack callback_url — MUST be set correctly in Railway or payments redirect to localhost.
FRONTEND_URL=https://YOUR_VERCEL_DOMAIN.vercel.app

# Comma-separated frontend origins allowed by CORS.
# Railway production: https://YOUR_VERCEL_DOMAIN.vercel.app
# Local dev: http://localhost:5173
ALLOWED_ORIGINS=https://YOUR_VERCEL_DOMAIN.vercel.app

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_ADMIN_CHAT_ID
TELEGRAM_BOT_USERNAME=your_bot_username

# ── Admin auth ────────────────────────────────────────────────────────────────
ADMIN_PASSWORD=choose_a_strong_password
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=generate_64_char_hex_string

# ── Email delivery ────────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxx
EMAIL_FROM_ADDRESS=hello@yourdomain.com
EMAIL_FROM_NAME=YOUR_BRAND

# ── WhatsApp ──────────────────────────────────────────────────────────────────
WHATSAPP_PROVIDER=meta_cloud
WHATSAPP_ACCESS_TOKEN=YOUR_META_ACCESS_TOKEN
WHATSAPP_PHONE_NUMBER_ID=YOUR_PHONE_NUMBER_ID
WHATSAPP_BUSINESS_ACCOUNT_ID=YOUR_BUSINESS_ACCOUNT_ID
WHATSAPP_DEFAULT_COUNTRY_CODE=234

# ── Paystack ──────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_live_YOUR_KEY

# Academy pricing — leave blank to use code defaults (50000 / 60000 NGN)
BASIC_PRICE_NGN=
PREMIUM_PRICE_NGN=

# ── Apify (Instagram scraping) ────────────────────────────────────────────────
APIFY_API_TOKEN=apify_api_YOUR_TOKEN
APIFY_COMMENT_ACTOR_ID=apify/instagram-comment-scraper

# ── n8n Academy Sync ──────────────────────────────────────────────────────────
# REQUIRED in production. n8n HTTP node must send this in x-sync-secret header.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If not set in production, the /api/academy/sync endpoint will return 503.
ACADEMY_SYNC_SECRET=generate_strong_random_secret

# ── Optional overrides ────────────────────────────────────────────────────────
# Links sent to leads via Telegram. Defaults already point to the Vercel domain.
# Only set these if you use a custom domain or need to override the defaults.
# ACADEMY_LINK=https://your-frontend.com/academy
# WHATSAPP_LINK=https://wa.me/+234XXXXXXXXXX
